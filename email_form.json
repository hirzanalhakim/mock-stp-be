{
  "screenId": "email_form",
  "version": 1,
  "schema": {
    "type": "object",
    "properties": {
      "emailAddress": {
        "type": "email",
        "maxLength": 200,
        "messages": {
          "required": "Email address is required",
          "email": "Please enter a valid email address"
        }
      },
      "confirmEmailAddress": {
        "type": "email",
        "maxLength": 200,
        "messages": {
          "required": "Confirm email address is required",
          "email": "Please enter a valid email address",
          "matchField": "Email addresses do not match"
        },
        "validations": [
          {
            "type": "MATCH_FIELD",
            "field": "emailAddress"
          }
        ]
      }
    },
    "required": [
      "emailAddress",
      "confirmEmailAddress"
    ]
  },
  "uiSchema": {
    "header": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "Control",
          "component": "NavigationHeader",
          "options": {
            "id": "screenHeader",
            "title": "Apply",
            "subtitle": "",
            "enableBackButton": true,
            "enableCloseButton": true
          }
        },
        {
          "type": "Control",
          "component": "ProgressIndicator",
          "options": {
            "id": "progressBar",
            "type": "stepper",
            "currentStep": 1,
            "totalSteps": 4,
            "showStepText": true
          }
        }
      ]
    },
    "body": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "Control",
          "component": "Typo",
          "options": {
            "id": "productName",
            "variant": "body",
            "value": "",
            "valueSource": {
              "type": "binding",
              "path": "product.name"
            }
          }
        },
        {
          "type": "Control",
          "component": "Typo",
          "options": {
            "id": "detailsTitle",
            "variant": "title1",
            "value": "Employment details"
          }
        },
        {
          "type": "Control",
          "component": "Typo",
          "options": {
            "id": "detailsSubtitle",
            "variant": "body",
            "value": "Fill in your email address"
          }
        },
        {
          "type": "Control",
          "component": "TextInput",
          "scope": "#/properties/emailAddress",
          "label": "Email address",
          "options": {
            "id": "emailAddress",
            "placeholder": "Enter email address",
            "keyboardType": "email",
            "span": 12
          }
        },
        {
          "type": "Control",
          "component": "TextInput",
          "scope": "#/properties/confirmEmailAddress",
          "label": "Confirm email address",
          "options": {
            "id": "confirmEmailAddress",
            "placeholder": "Re-enter email address",
            "keyboardType": "email",
            "span": 12
          }
        }
      ]
    },
    "footer": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "Control",
          "component": "Button",
          "label": "Next",
          "options": {
            "id": "nextButton",
            "variant": "primary",
            "action": {
              "type": "submit"
            }
          }
        },
        {
          "type": "Control",
          "component": "Divider",
          "label": "Or continue with an account",
          "options": {
            "id": "footerDivider"
          }
        },
        {
          "type": "Control",
          "component": "Button",
          "label": "Continue with Google",
          "options": {
            "id": "googleAccountButton",
            "variant": "secondary",
            "iconName": "googleLogo",
            "iconPosition": "left",
            "action": {
              "type": "navigate",
              "target": "GoogleAuthMFE"
            }
          }
        },
        {
          "type": "Control",
          "component": "Button",
          "label": "Continue with Apple",
          "options": {
            "id": "appleAccountButton",
            "variant": "secondary",
            "iconName": "appleLogo",
            "iconPosition": "left",
            "action": {
              "type": "navigate",
              "target": "AppleAuthMFE"
            }
          }
        }
      ]
    }
  },
  "data": {
    "emailAddress": "",
    "confirmEmailAddress": ""
  }
}