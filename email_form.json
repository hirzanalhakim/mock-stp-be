{
  "screenId": "complete-form-example",
  "version": 1,
  "schema": {
    "type": "object",
    "properties": {
      "firstName": {
        "type": "string",
        "minLength": 2,
        "maxLength": 50,
        "messages": {
          "required": "First name is required",
          "minLength": "Minimum 2 characters"
        }
      },
      "lastName": {
        "type": "string",
        "minLength": 2,
        "maxLength": 50,
        "messages": {
          "required": "Last name is required"
        }
      },
      "emailAddress": {
        "type": "string",
        "minLength": 5,
        "maxLength": 200,
        "messages": {
          "required": "Email is required",
          "email": "Enter a valid email address",
          "minLength": "Email must be at least 5 characters",
          "maxLength": "Email must be at most 200 characters"
        }
      },
      "country": {
        "type": "string",
        "messages": {
          "required": "Please select a country"
        },
        "oneOf": [
          {
            "const": "MY",
            "title": "Malaysia"
          },
          {
            "const": "SG",
            "title": "Singapore"
          },
          {
            "const": "TH",
            "title": "Thailand"
          },
          {
            "const": "ID",
            "title": "Indonesia"
          }
        ]
      },
      "contactMethod": {
        "type": "string",
        "messages": {
          "required": "Please select a contact method"
        },
        "oneOf": [
          {
            "const": "email",
            "title": "Email"
          },
          {
            "const": "phone",
            "title": "Phone Call"
          },
          {
            "const": "sms",
            "title": "SMS"
          }
        ]
      },
      "phoneNumber": {
        "type": "string"
      },
      "foreignId": {
        "type": "string"
      },
      "areaCode": {},
      "notifications": {
        "type": "array",
        "uniqueItems": true,
        "items": {
          "oneOf": [
            {
              "const": "news",
              "title": "News & Updates"
            },
            {
              "const": "promos",
              "title": "Promotions"
            },
            {
              "const": "reminders",
              "title": "Reminders"
            }
          ]
        }
      },
      "agreeToTerms": {
        "messages": {
          "required": "You must agree to the terms"
        }
      },
      "promoCode": {
        "type": "string"
      },
      "discountLevel": {},
      "quantity": {},
      "verificationPin": {
        "messages": {
          "required": "Verification PIN is required"
        }
      },
      "supportingDocs": {}
    },
    "required": [
      "firstName",
      "lastName",
      "emailAddress",
      "country",
      "contactMethod",
      "agreeToTerms",
      "verificationPin"
    ]
  },
  "uiSchema": {
    "header": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "Control",
          "component": "TopNavigation",
          "options": {
            "id": "topNav",
            "title": "Complete Form Example",
            "disableSafeArea": false
          }
        },
        {
          "type": "Control",
          "component": "Typo",
          "options": {
            "id": "screenTitle",
            "value": "All Conditions Demo",
            "textAlign": "center"
          }
        }
      ]
    },
    "body": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "HorizontalLayout",
          "elements": [
            {
              "type": "Control",
              "component": "TextInput",
              "options": {
                "id": "firstName",
                "placeholder": "Enter first name",
                "disabled": false
              },
              "label": "First Name"
            },
            {
              "type": "Control",
              "component": "TextInput",
              "options": {
                "id": "lastName",
                "placeholder": "Enter last name",
                "disabled": false
              },
              "label": "Last Name"
            }
          ]
        },
        {
          "type": "Control",
          "component": "TextInput",
          "options": {
            "id": "emailAddress",
            "placeholder": "Enter your email",
            "disabled": false
          },
          "label": "Email Address",
          "dynamic": {
            "id": 8,
            "enabled": true,
            "type": "VALUE",
            "target": "defaultValue",
            "source": {
              "id": 8,
              "type": "FACT",
              "path": "userEmail",
              "serviceCode": null
            }
          }
        },
        {
          "type": "Control",
          "component": "Dropdown",
          "options": {
            "id": "country",
            "placeholder": "Select your country",
            "disabled": false
          },
          "label": "Country"
        },
        {
          "type": "Control",
          "component": "RadioButton",
          "options": {
            "id": "contactMethod",
            "groupDirection": "vertical",
            "disabled": false
          },
          "label": "Preferred Contact Method"
        },
        {
          "type": "Control",
          "component": "TextInput",
          "options": {
            "id": "phoneNumber",
            "placeholder": "+60 12 345 6789",
            "disabled": false
          },
          "label": "Phone Number",
          "dependsOn": [
            "contactMethod"
          ],
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/contactMethod",
              "schema": {
                "const": "phone"
              }
            }
          }
        },
        {
          "type": "Control",
          "component": "TextInput",
          "options": {
            "id": "foreignId",
            "placeholder": "Enter foreign identification number",
            "disabled": false
          },
          "label": "Foreign ID Number",
          "rule": {
            "effect": "HIDE",
            "condition": {
              "scope": "#/properties/country",
              "schema": {
                "const": "MY"
              }
            }
          }
        },
        {
          "type": "Control",
          "component": "SearchInput",
          "options": {
            "id": "areaCode",
            "placeholder": "Search area code",
            "disabled": false
          },
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/contactMethod",
              "schema": {
                "enum": [
                  "phone",
                  "sms"
                ]
              }
            }
          }
        },
        {
          "type": "Control",
          "component": "Checkbox",
          "options": {
            "id": "notifications",
            "disabled": false
          },
          "label": "Notification Preferences"
        },
        {
          "type": "Control",
          "component": "Toggle",
          "options": {
            "id": "agreeToTerms",
            "size": "md",
            "disabled": false
          }
        },
        {
          "type": "Control",
          "component": "TextInput",
          "options": {
            "id": "promoCode",
            "placeholder": "Enter promo code (optional)",
            "disabled": false
          },
          "label": "Promo Code",
          "dependsOn": [
            "agreeToTerms"
          ],
          "rule": {
            "effect": "ENABLE",
            "condition": {
              "scope": "#/properties/agreeToTerms",
              "schema": {
                "const": true
              }
            }
          }
        },
        {
          "type": "Control",
          "component": "Slider",
          "options": {
            "id": "discountLevel",
            "min": 0,
            "max": 100,
            "step": 10
          },
          "label": "Discount Level (%)",
          "rule": {
            "effect": "DISABLE",
            "condition": {
              "scope": "#/properties/agreeToTerms",
              "schema": {
                "const": false
              }
            }
          }
        },
        {
          "type": "Control",
          "component": "NumberInputStepper",
          "options": {
            "id": "quantity",
            "min": 1,
            "max": 99,
            "step": 1,
            "editable": true
          },
          "label": "Quantity"
        },
        {
          "type": "Control",
          "component": "PinInput",
          "options": {
            "id": "verificationPin",
            "numberOfDigits": 6,
            "inputMode": "numeric",
            "secureTextEntry": false,
            "autoFocus": false
          }
        },
        {
          "type": "Control",
          "component": "Uploader",
          "options": {
            "id": "supportingDocs",
            "maxFiles": 3,
            "maxFileSizeBytes": 5242880,
            "autoUpload": false,
            "disabled": false
          }
        }
      ]
    },
    "footer": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "Control",
          "component": "Button",
          "options": {
            "id": "submitButton",
            "variant": "primary",
            "size": "lg",
            "disabled": false,
            "loading": false
          },
          "label": "Submit"
        }
      ]
    }
  },
  "data": {
    "firstName": "",
    "lastName": "",
    "emailAddress": "",
    "country": "",
    "contactMethod": "",
    "phoneNumber": "",
    "foreignId": "",
    "areaCode": "",
    "notifications": [],
    "agreeToTerms": "",
    "promoCode": "",
    "discountLevel": "",
    "quantity": "",
    "verificationPin": "",
    "supportingDocs": ""
  }
}