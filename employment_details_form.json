{
  "screenId": "employment_details_form",
  "version": 1,
  "schema": {
    "type": "object",
    "properties": {
      "companyName": {
        "type": "text",
        "maxLength": 200,
        "messages": {
          "required": "Company name is required",
          "maxLength": "Company name must be at most 200 characters"
        }
      },
      "officePhoneNumber": {
        "type": "text",
        "maxLength": 12,
        "messages": {
          "required": "Office phone number is required",
          "maxLength": "Office phone number must be at most 12 digits"
        }
      },
      "officeAddress": {
        "type": "text",
        "maxLength": 300,
        "messages": {
          "required": "Office address is required",
          "maxLength": "Office address must be at most 300 characters"
        }
      },
      "addressRT": {
        "type": "text",
        "maxLength": 3,
        "pattern": "^[0-9]{1,3}$",
        "messages": {
          "pattern": "RT must be 1-3 digits (numbers only)"
        }
      },
      "addressRW": {
        "type": "text",
        "maxLength": 3,
        "pattern": "^[0-9]{1,3}$",
        "messages": {
          "pattern": "RW must be 1-3 digits (numbers only)"
        }
      }
    },
    "required": [
      "companyName",
      "officePhoneNumber",
      "officeAddress"
    ]
  },
  "uiSchema": {
    "header": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "Control",
          "component": "NavigationHeader",
          "options": {
            "id": "screenHeader",
            "title": "Apply",
            "subtitle": "",
            "enableBackButton": true,
            "enableCloseButton": true
          }
        },
        {
          "type": "Control",
          "component": "ProgressIndicator",
          "options": {
            "id": "progressBar",
            "type": "stepper",
            "currentStep": 3,
            "totalSteps": 4,
            "showStepText": true
          }
        }
      ]
    },
    "body": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "Control",
          "component": "Typo",
          "options": {
            "id": "productName",
            "variant": "body",
            "value": "",
            "valueSource": {
              "type": "binding",
              "path": "product.name"
            }
          }
        },
        {
          "type": "Control",
          "component": "Typo",
          "options": {
            "id": "detailsTitle",
            "variant": "title1",
            "value": "Employment details"
          }
        },
        {
          "type": "Control",
          "component": "TextInput",
          "scope": "#/properties/companyName",
          "label": "Company name",
          "options": {
            "id": "employmentCompanyName",
            "placeholder": "Enter company name",
            "keyboardType": "text",
            "conditions": {
              "visibility": {
                "field": "industryCategory",
                "operator": "NOT_EMPTY"
              }
            },
            "span": 12
          }
        },
        {
          "type": "Control",
          "component": "TextInput",
          "scope": "#/properties/officePhoneNumber",
          "label": "Office phone number",
          "options": {
            "id": "employmentOfficePhoneNumber",
            "keyboardType": "numeric",
            "prefix": "+62",
            "conditions": {
              "visibility": {
                "field": "industryCategory",
                "operator": "NOT_EMPTY"
              }
            },
            "span": 12
          }
        },
        {
          "type": "Control",
          "component": "TextInput",
          "scope": "#/properties/officeAddress",
          "label": "Office address",
          "options": {
            "id": "employmentOfficeAddress",
            "placeholder": "Enter office address",
            "keyboardType": "text",
            "conditions": {
              "visibility": {
                "field": "industryCategory",
                "operator": "NOT_EMPTY"
              }
            },
            "span": 12
          }
        },
        {
          "type": "Control",
          "component": "TextInput",
          "scope": "#/properties/addressRW",
          "label": "RW",
          "options": {
            "id": "employmentAddressRW",
            "placeholder": "Enter RW",
            "keyboardType": "numeric",
            "conditions": {
              "visibility": {
                "field": "industryCategory",
                "operator": "NOT_EMPTY"
              }
            },
            "span": 6
          }
        },
        {
          "type": "Control",
          "component": "TextInput",
          "scope": "#/properties/addressRT",
          "label": "RT",
          "options": {
            "id": "employmentAddressRT",
            "placeholder": "Enter RT",
            "keyboardType": "numeric",
            "conditions": {
              "visibility": {
                "field": "industryCategory",
                "operator": "NOT_EMPTY"
              }
            },
            "span": 6
          }
        }
      ]
    },
    "footer": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "Control",
          "component": "Button",
          "label": "Next",
          "options": {
            "id": "nextButton",
            "variant": "primary",
            "action": {
              "type": "submit"
            }
          }
        }
      ]
    }
  },
  "data": {
    "companyName": "",
    "officePhoneNumber": "",
    "officeAddress": "",
    "addressRT": "",
    "addressRW": ""
  }
}
